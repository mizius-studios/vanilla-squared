{
  "version": "1.0.0",
  "paths": {
    "gradleProperties": "gradle.properties",
    "buildGradle": "build.gradle",
    "gradleWrapper": ".\\gradlew.bat",
    "buildLibs": "build\\libs",
    "fabricModJson": "src/main/resources/fabric.mod.json",
    "texturesRoot": "blobManager/textures/skins",
    "skinPacksRoot": "blobManager/skinPacks",
    "defaultSkinsRoot": "src/client/resources/assets/minecraft/textures/entity/player",
    "runConfig": ".idea/runConfigurations"
  },
  "markers": {
    "username": "usernameVSQ",
    "model": "modelVSQ",
    "modVersion": "mod_version"
  },
  "defaults": {
    "username": "TESTIFICATE",
    "model": "wide"
  },
  "skins": {
    "supportedNames": ["alex", "steve", "ari", "efe", "makena", "kai", "noor", "sunny", "zuri"],
    "supportedModels": ["slim", "wide"]
  },
  "intellij": {
    "runConfigurations": {
      "client": {
        "path": ".idea/runConfigurations/Minecraft_Client.xml"
      },
      "server": {
        "path": ".idea/runConfigurations/Minecraft_Server.xml",
        "programParameters": "nogui"
      },
      "dataGeneration": {
        "path": ".idea/runConfigurations/Data_Generation.xml",
        "programParameters": ""
      }
    }
  }
}
